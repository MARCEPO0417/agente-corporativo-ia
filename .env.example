# --- Cohere (proveedor temporal, plan trial) ---
COHERE_API_KEY=your_cohere_trial_api_key

# --- OCI Generative AI ---
# Si no tienes compartments propios, el compartment raíz (= tenancy OCID) sirve.
OCI_COMPARTMENT_ID=ocid1.tenancy.oc1..xxxxxxxx
OCI_GENAI_ENDPOINT=https://inference.generativeai.<region>.oci.oraclecloud.com
# embed-multilingual-v3.0 está deprecado (retiro 2026-09-30) -> usar embed-v4.0
OCI_GENAI_EMBEDDING_MODEL_ID=cohere.embed-v4.0
OCI_GENAI_CHAT_MODEL_ID=cohere.command-a-03-2025

# --- Autenticación OCI ---
# Opción 1: perfil de config file (recomendado en local)
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT

# Opción 2: Instance Principal (recomendado en despliegue dentro de OCI Compute)
OCI_USE_INSTANCE_PRINCIPAL=false

# --- Vector store ---
VECTORSTORE_PATH=./data/vectorstore
VECTORSTORE_BACKEND=faiss   # faiss | chroma

# --- App ---
APP_ENV=development
